ROLLOUT_PROJECT_LABEL=Subtitle Rollout
ROLLOUT_PROJECT_SLUG=subtitle_rollout
# Optional: keep episode workspaces outside this repository.
# ROLLOUT_WORKSPACE_ROOT=<DATA_ROOT>
ROLLOUT_EPISODE_WORKDIR_TEMPLATE=episode-{episode:02d}
ROLLOUT_EPISODE_OUTPUT_STEM_TEMPLATE=episode-{episode:02d}
ROLLOUT_REFERENCE_DIR=reference_subtitles
ROLLOUT_REFERENCE_FILENAME_TEMPLATE=episode-{episode:02d}.srt
# Optional: point to custom prompt files.
# ROLLOUT_PROMPT_PATH=<PROMPT_FILE>
# ROLLOUT_STRICT_PROMPT_PATH=<STRICT_PROMPT_FILE>
GEMINI_UI_PYTHON=python
GEMINI_UI_VISIBLE_WINDOW=0
GEMINI_BATCH_TIMEOUT_BASE_SECONDS=180
GEMINI_BATCH_TIMEOUT_PER_SEGMENT_SECONDS=240
CODEX_RESUME_TIMEOUT_SECONDS=120
CODEX_RESUME_MAX_FAILURES=3
